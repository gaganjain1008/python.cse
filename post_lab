# File Encryption & Decryption using Caesar Cipher

def encrypt_text(text, shift):
    result = ""
    for char in text:
        if char.isalpha():
            if char.isupper():
                result += chr((ord(char) + shift - 65) % 26 + 65)
            else:
                result += chr((ord(char) + shift - 97) % 26 + 97)
        else:
            result += char
    return result


def decrypt_text(text, shift):
    return encrypt_text(text, -shift)


def encrypt_file(input_file, output_file, shift):
    try:
        with open(input_file, 'r') as file:
            text = file.read()

        encrypted = encrypt_text(text, shift)

        with open(output_file, 'w') as file:
            file.write(encrypted)

        print("✅ File encrypted successfully!")

    except FileNotFoundError:
        print("❌ Error: Input file not found!")
    except Exception as e:
        print("❌ Error:", e)


def decrypt_file(input_file, output_file, shift):
    try:
        with open(input_file, 'r') as file:
            text = file.read()

        decrypted = decrypt_text(text, shift)

        with open(output_file, 'w') as file:
            file.write(decrypted)

        print("✅ File decrypted successfully!")

    except FileNotFoundError:
        print("❌ Error: Input file not found!")
    except Exception as e:
        print("❌ Error:", e)

print("1. Encrypt File")
print("2. Decrypt File")

choice = input("Enter your choice (1/2): ")

input_file = input("Enter input file name: ")
output_file = input("Enter output file name: ")
shift = int(input("Enter shift key (number): "))

if choice == '1':
    encrypt_file(input_file, output_file, shift)
elif choice == '2':
    decrypt_file(input_file, output_file, shift)
else:
    print("❌ Invalid choice!")

# Taking file names from user
source_file = input("Enter source file name: ")
dest_file = input("Enter destination file name: ")

# Open files
src = open(source_file, "r")
dest = open(dest_file, "w")

print("\n--- Source File Content ---")
for line in src:
    print(line, end="")
    
    # Skip comments (lines starting with #)
    if not line.strip().startswith("#"):
        dest.write(line)

src.close()
dest.close()

# Display destination file content
print("\n\n--- Destination File Content (Without Comments) ---")
dest = open(dest_file, "r")
print(dest.read())
dest.close()
